# App
NEXT_PUBLIC_APP_URL=https://criation.io
NEXT_PUBLIC_APP_DOMAIN=app.criation.io
NEXT_PUBLIC_ADMIN_DOMAIN=adm.criation.io
NODE_ENV=development

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Database
DATABASE_URL=

# Anthropic
ANTHROPIC_API_KEY=

# Trigger.dev v3
TRIGGER_SECRET_KEY=
TRIGGER_API_URL=

# Resend (transactional email)
RESEND_API_KEY=
# Optional override; default 'Criation <noreply@criation.io>'
RESEND_FROM_EMAIL=

# Sentry
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=

# PostHog
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# Better Stack
BETTERSTACK_SOURCE_TOKEN=

# Asaas
ASAAS_API_KEY=
ASAAS_WEBHOOK_SECRET=

# Stripe
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# Upstash Redis (rate limit) — required
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Hash salt for PII (IP/UA/fingerprint) — required
# Generate with: openssl rand -base64 32
HASH_SALT=

# Encryption — 32 bytes hex — openssl rand -hex 32
ENCRYPTION_KEY=

# Skip env validation during build (CI)
SKIP_ENV_VALIDATION=
